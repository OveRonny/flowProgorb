# Required — application authentication
JWT_SECRET=your-strong-random-secret-here
JWT_EXPIRES_IN=30d

# Required — PostgreSQL connection string
# Azure Database for PostgreSQL Flexible Server format:
DATABASE_URL=postgresql://<user>:<password>@<server>.postgres.database.azure.com:5432/<dbname>?sslmode=require

# Required — where the frontend is hosted (used in OAuth redirects)
FRONTEND_URL=https://your-static-web-app.azurestaticapps.net

# Required for GitHub OAuth login
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# Required for GitHub App (repo connect, issue creation, branch actions)
GITHUB_APP_ID=your-github-app-id
GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Required for webhook HMAC signature verification
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Optional — defaults to 3000
PORT=8080
