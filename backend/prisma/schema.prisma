// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  password    String
  githubLogin String?   @unique
  projectMemberships ProjectMember[]
  assignedTasks      Task[]
  meetingAttendances CustomerMeeting[] @relation("MeetingAttendees")
  createdAt DateTime @default(now())
}

model ProjectMember {
  id        Int    @id @default(autoincrement())

  user      User   @relation(fields: [userId], references: [id])
  userId    Int

  project   Project @relation(fields: [projectId], references: [id])
  projectId Int

  role      ProjectRole @default(MEMBER)

  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Project {
  id          Int     @id @default(autoincrement())
  members ProjectMember[]
  name        String
  description String?
  hourlyRate  Int?
  offerPrice  Int?

  githubRepoUrl       String?
  githubRepoId        Int?
  githubDefaultBranch String?
  githubOwner         String?
  githubRepoName      String?
  features            Feature[]
  status              ProjectStatus   @default(PLANNED)  
  deadline            DateTime?
  priority            Int?
  tags                String[]
  modules             Module[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  activities          Activity[]
  customerMeetings    CustomerMeeting[]
  emails              ProjectEmail[]
  requirements Requirement[]
  milestones   Milestone[]
  versions     ReleaseVersion[]
 
}

model ProjectEmail {
  id         Int      @id @default(autoincrement())
  project     Project  @relation(fields: [projectId], references: [id])
  projectId    Int

  subject     String
  sender      String?
  recipients  String[]
  summary     String?
  sentAt      DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

model ReleaseVersion {
  id          Int      @id @default(autoincrement())
  project     Project  @relation(fields: [projectId], references: [id])
  projectId   Int

  versionTag  String
  name        String?
  channel     ReleaseChannel @default(DEVELOPMENT)
  status      ReleaseStatus  @default(PLANNED)
  releaseDate DateTime?

  requirements Requirement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, versionTag])
  @@index([projectId])
}

enum ReleaseChannel {
  DEVELOPMENT
  RELEASE
}

enum ReleaseStatus {
  PLANNED
  APPROVED
  RELEASED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ON_HOLD
}

model Module {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  features Feature[]

  orderIndex Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
}

model Feature {
  id               Int           @id @default(autoincrement())
  module           Module        @relation(fields: [moduleId], references: [id])
  moduleId         Int
  project          Project       @relation(fields: [projectId], references: [id])
  projectId        Int
  name             String
  description      String?
  status           FeatureStatus @default(PLANNED) 
  githubBranchName String?
  githubPRId       Int?
  githubPRUrl      String?
  githubPRState    String?
  githubSyncedAt   DateTime?
  orderIndex       Int?

  requirement   Requirement? @relation(fields: [requirementId], references: [id])
  requirementId Int?

  tasks        Task[]
  technologies Technology[]

  @@unique([projectId, moduleId, name])
  @@index([projectId])
  @@index([moduleId])
}

enum FeatureStatus {
  PLANNED
  IN_PROGRESS
  DONE
}

model Task {
  id             Int        @id @default(autoincrement())
  feature        Feature    @relation(fields: [featureId], references: [id])
  featureId      Int
  title          String
  description    String?
  status         TaskStatus @default(PENDING)
  estimatedHours Int?
  completedAt    DateTime?
  assignedTo     User? @relation(fields: [assignedToId], references: [id])
  assignedToId   Int?
  githubIssueId        Int?
  githubIssueUrl       String?
  githubIssueState     String?
  githubIssueSyncedAt  DateTime?

  githubCommentId Int?
  githubPRId      Int?
  githubUrl       String?
  orderIndex      Int?

  timeLogs TaskTimeLog[]

  @@unique([featureId, title])
  @@index([featureId])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model TaskTimeLog {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id])

  minutes   Int
  note      String?

  createdAt DateTime @default(now())
  @@index([taskId])
}

model Technology {
  id   Int    @id @default(autoincrement())
  name String @unique
  type TechnologyType

  features Feature[]
}

enum TechnologyType {
  LANGUAGE
  FRAMEWORK
  LIBRARY
}

model Activity {
  id Int @id @default(autoincrement())

  type ActivityType

  project   Project @relation(fields: [projectId], references: [id])
  projectId Int
  metadata Json?

  createdAt DateTime @default(now())
}

enum ActivityType {
  TASK_CREATED
  TASK_COMPLETED
  FEATURE_CREATED
  FEATURE_COMPLETED
  REQUIREMENT_CREATED
  REQUIREMENT_APPROVED
  MILESTONE_COMPLETED
  CUSTOMER_MEETING_LOGGED
  PROJECT_UPDATED
}

model CustomerMeeting {
  id        Int       @id @default(autoincrement())
  project   Project   @relation(fields: [projectId], references: [id])
  projectId Int

  title     String
  notes     String?
  date      DateTime @default(now())

  attendees User[] @relation("MeetingAttendees")
  requirements Requirement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Requirement {
  id          Int       @id @default(autoincrement())
  project     Project   @relation(fields: [projectId], references: [id])
  projectId   Int

  title       String
  description String?
  priority    Int?
  estimatedHours Float?

  status RequirementStatus @default(OPEN)
  
  meeting   CustomerMeeting? @relation(fields: [meetingId], references: [id])
  meetingId Int?

  targetVersion   ReleaseVersion? @relation(fields: [targetVersionId], references: [id])
  targetVersionId Int?

  features  Feature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

enum RequirementStatus {
  OPEN
  APPROVED
  IMPLEMENTED
  REJECTED
}

model Milestone {
  id          Int       @id @default(autoincrement())
  project     Project   @relation(fields: [projectId], references: [id])
  projectId   Int

  title       String
  description String?
  dueDate     DateTime?

  completed   Boolean @default(false)

  orderIndex  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}


