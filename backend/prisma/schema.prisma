// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  password String
  projects Project[]
}

model Project {
  id          Int     @id @default(autoincrement())
  user        User    @relation(fields: [userId], references: [id])
  userId      Int
  name        String
  description String?

  githubRepoUrl       String?
  githubRepoId        Int?
  githubDefaultBranch String?
  features            Feature[]
  status              ProjectStatus   @default(PLANNED)
  progress            Int             @default(0)
  deadline            DateTime?
  priority            Int?
  tags                String[]
  modules             ProjectModule[] 
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([userId, name])
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ON_HOLD
}

model Module {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  projectModules ProjectModule[]
  features       Feature[]
}

model ProjectModule {
  id Int @id @default(autoincrement())

  project   Project @relation(fields: [projectId], references: [id])
  projectId Int

  module   Module @relation(fields: [moduleId], references: [id])
  moduleId Int

  orderIndex Int?

  @@unique([projectId, moduleId])
}

model Feature {
  id               Int           @id @default(autoincrement())
  module           Module        @relation(fields: [moduleId], references: [id])
  moduleId         Int
  project          Project       @relation(fields: [projectId], references: [id])
  projectId        Int
  name             String
  description      String?
  status           FeatureStatus @default(PLANNED)
  progress         Int           @default(0)
  githubIssueId    Int?
  githubIssueUrl   String?
  githubIssueState String?
  orderIndex       Int?

  tasks        Task[]
  technologies Technology[]

  @@unique([projectId, moduleId, name])
}

enum FeatureStatus {
  PLANNED
  IN_PROGRESS
  DONE
}

model Task {
  id             Int        @id @default(autoincrement())
  feature        Feature    @relation(fields: [featureId], references: [id])
  featureId      Int
  title          String
  description    String?
  status         TaskStatus @default(PENDING)
  estimatedHours Int?
  completedAt    DateTime?

  githubCommentId Int?
  githubPRId      Int?
  githubUrl       String?
  orderIndex      Int?

  @@unique([featureId, title])
}

enum TaskStatus {
  PENDING
  COMPLETED
}

model Technology {
  id   Int    @id @default(autoincrement())
  name String @unique
  type TechnologyType

  features Feature[]
}

enum TechnologyType {
  LANGUAGE
  FRAMEWORK
  LIBRARY
}


