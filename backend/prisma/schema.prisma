// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  password String
  projectMemberships ProjectMember[]
  assignedTasks      Task[]
}

model ProjectMember {
  id        Int    @id @default(autoincrement())

  user      User   @relation(fields: [userId], references: [id])
  userId    Int

  project   Project @relation(fields: [projectId], references: [id])
  projectId Int

  role      ProjectRole @default(MEMBER)

  createdAt DateTime @default(now())

  @@unique([userId, projectId])
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Project {
  id          Int     @id @default(autoincrement())
  members ProjectMember[]
  name        String
  description String?

  githubRepoUrl       String?
  githubRepoId        Int?
  githubDefaultBranch String?
  githubOwner         String?
  githubRepoName      String?
  features            Feature[]
  status              ProjectStatus   @default(PLANNED)  
  deadline            DateTime?
  priority            Int?
  tags                String[]
  modules             Module[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  activities          Activity[]
 
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ON_HOLD
}

model Module {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  features Feature[]

  orderIndex Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
}

model Feature {
  id               Int           @id @default(autoincrement())
  module           Module        @relation(fields: [moduleId], references: [id])
  moduleId         Int
  project          Project       @relation(fields: [projectId], references: [id])
  projectId        Int
  name             String
  description      String?
  status           FeatureStatus @default(PLANNED) 
  githubIssueId    Int?
  githubIssueUrl   String?
  githubIssueState String?
  githubBranchName String?
  githubSyncedAt   DateTime?
  orderIndex       Int?

  tasks        Task[]
  technologies Technology[]

  @@unique([projectId, moduleId, name])
  @@index([projectId])
  @@index([moduleId])
}

enum FeatureStatus {
  PLANNED
  IN_PROGRESS
  DONE
}

model Task {
  id             Int        @id @default(autoincrement())
  feature        Feature    @relation(fields: [featureId], references: [id])
  featureId      Int
  title          String
  description    String?
  status         TaskStatus @default(PENDING)
  estimatedHours Int?
  completedAt    DateTime?
  assignedTo     User? @relation(fields: [assignedToId], references: [id])
  assignedToId   Int?

  githubCommentId Int?
  githubPRId      Int?
  githubUrl       String?
  orderIndex      Int?

  timeLogs TaskTimeLog[]

  @@unique([featureId, title])
  @@index([featureId])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model TaskTimeLog {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id])

  minutes   Int
  note      String?

  createdAt DateTime @default(now())
  @@index([taskId])
}

model Technology {
  id   Int    @id @default(autoincrement())
  name String @unique
  type TechnologyType

  features Feature[]
}

enum TechnologyType {
  LANGUAGE
  FRAMEWORK
  LIBRARY
}

model Activity {
  id Int @id @default(autoincrement())

  type ActivityType

  project   Project @relation(fields: [projectId], references: [id])
  projectId Int

  createdAt DateTime @default(now())
}

enum ActivityType {
  TASK_CREATED
  TASK_COMPLETED
  FEATURE_CREATED
  FEATURE_COMPLETED
  PROJECT_UPDATED
}


